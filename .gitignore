# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environments
.venv/
venv/
env/

# Streamlit cache
.streamlit/secrets.toml
.streamlit/cache/

# Distribution / packaging
dist/
build/
*.egg-info/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# macOS
.DS_Store
.AppleDouble

# IDE
.idea/
.vscode/
*.swp

# Temporary / uploaded files
*.tmp
tmp/
uploads/

# Model artifacts (typically too large for git)
*.pt
!tests/fixtures/*.pt
